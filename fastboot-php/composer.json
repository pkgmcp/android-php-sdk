{
    "name": "fastboot-php/fastboot-php",
    "description": "PHP implementation of the Android Fastboot protocol — full port of fastboot.js",
    "type": "library",
    "version": "1.0.0",
    "license": "MIT",
    "keywords": ["android", "fastboot", "usb", "adb", "bootloader", "flash"],
    "authors": [
        {
            "name": "fastboot-php contributors",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "FastbootPhp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FastbootPhp\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "config": {
        "platform": {
            "php": "8.3.0"
        }
    }
}
