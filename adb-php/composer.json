{
    "name": "adb-php/adb-php",
    "description": "Pure PHP ADB client — full port of @devicefarmer/adbkit v3 for PHP 8.3+",
    "type": "library",
    "version": "1.0.0",
    "license": "Apache-2.0",
    "keywords": ["android", "adb", "adbkit", "debug", "shell", "logcat", "apk", "install"],
    "authors": [
        { "name": "adb-php contributors", "role": "Developer" }
    ],
    "require": {
        "php": ">=8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "AdbPhp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AdbPhp\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "config": {
        "platform": {
            "php": "8.3.0"
        }
    }
}
